{
  "name": "asl-data-catalog",
  "version": "2.0.0",
  "description": "ASL Aviation Enterprise Data Catalog — dynamic Dremio sync",
  "type": "commonjs",
  "scripts": {
    "sync":           "node scripts/sync-catalog.js",
    "sync:dry-run":   "node scripts/sync-catalog.js --dry-run --verbose",
    "sync:counts":    "node scripts/sync-catalog.js --with-counts",
    "serve":          "node catalog-api-server.js",
    "react:dev":      "vite",
    "react:build":    "vite build",
    "dev":            "concurrently \"npm run serve\" \"vite\"",
    "build":          "vite build",
    "preview":        "vite preview"
  },
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently":         "^8.2.2",
    "react":                "^18.2.0",
    "react-dom":            "^18.2.0",
    "vite":                 "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
